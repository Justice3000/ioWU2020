@model Item

@{
    ViewData["Title"] = "Create Item";
}
<h1> Current ID is </h1>


<div class="form-item">
<form asp-action="CreateItem" method="POST">
    <div class="form-group">
    <label asp-for="Name"></label>
    <input class="form-control"asp-for="Name" placeholder="Item's name"/>
    <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="SupplierName"></label>
        <input class="form-control"asp-for="SupplierName" placeholder="IKEA">
        <span asp-validation-for="SupplierName" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="SupplierPrice"></label>
        <input type="number" min="0.01" step="0.01"class="form-control"asp-for="SupplierPrice " placeholder="1245.68">
        <span asp-validation-for="SupplierPrice" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Quantity"></label>
        <input class="form-control"asp-for="Quantity" placeholder="11">
        <span asp-validation-for="Quantity" class="text-danger"></span>
    </div>

 <div class="form-group">
        <label asp-for="Url"></label>
        <textarea class="form-control"rows="2" cols="100" asp-for="Url" placeholder="https://www.example.com"></textarea>
        <span asp-validation-for="Url" class="text-danger"></span>
    </div>

     <div class="form-group">
        <label asp-for="LongImportantInfo"></label>
        <textarea class="form-control"rows="8" cols="100" asp-for="LongImportantInfo" placeholder="Lorem Ipsum"></textarea>
        <span asp-validation-for="LongImportantInfo" class="text-danger"></span>
    </div>
    
    <div>
<label asp-for="ItemOwner"></label>
<input disabled class="form-group" value="@Context.User.Identity.Name">
    </div>


 
        <div>
        <input type="hidden" asp-for="ProjectId">
        <input type="hidden" asp-for="ItemOwner" value="@Context.User.Identity.Name"/>
        </div>

    


    <div class="form-group">
        <input type="submit" value="Create Item" />
    </div>
</form>
</div>