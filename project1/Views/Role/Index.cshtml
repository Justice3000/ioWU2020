@model project1.ViewModels.RolesViewModel 
@{  
    ViewData["Title"] = "Users";  
}  

<div>

<table class="table table-striped table-bordered"> 
    <h2>List of Roles</h2>
     <thead>  
        <tr>  
            <td>Id</td>  
            <td>Role</td>

        </tr>  
    </thead>  
    <tbody>
        @foreach (var role in Model.roleManager)
        {
            <tr>
            <td>@role.Id</td>
            <td>@role.Name</td>
        </tr>
        }
    </tbody>
</div>

<div>
<table class="table table-striped table-bordered">  
    <h2>List of Users</h2>  
    <thead>  
        <tr>  
            <th>Name</th>  
            <th>Phone Number</th>

        </tr>  
    </thead>  
    <tbody>  
</div>    
             
                                 
            
                @foreach (var user in Model.userManager)
                {
                    <tr>
                    <td>@user.UserName</td>
                    <td>@user.PhoneNumber</td>
                    </tr>
                }
            
                  
           
          
    