@model project1.Project

@{
    ViewData["Title"] = "Edit Project";
    
}

<div class="form-project form-group">
<form asp-action="EditProject" method="POST">
    <div class="form-group">
    <label asp-for="Name"></label>
    <input asp-for="Name"/>
    <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Description"></label>
        <input asp-for="Description">
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>


  <div class="form-group">
                <label asp-for="ProjectOwner"></label>
                <input hidden asp-for="ProjectOwner" class="form-control" value="@Context.User.Identity.Name" />
                <input disabled class="form-group" value="@Context.User.Identity.Name">
                <input type="hidden" asp-for="ProjectId">
            </div>


    <div class="form-group">
        <input type="submit" value="Save Changes" />
    </div>
</form>
</div>
